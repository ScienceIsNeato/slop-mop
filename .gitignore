# Byte-compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# OS
.DS_Store
Thumbs.db

# Local environment overrides (direnv)
.envrc

# Logs
*.log
logs/

# cursor files
cursor-rules/

# Slopbucket config (user-specific, not template)
.sb_config.json
.sb_config.json.backup.*

# Generated status reports (from sm status --verbose)
sm_status_*.json

# Generated Copilot instructions (from cursor-rules)
.github/instructions/*.instructions.md
.github/copilot-instructions.md

# Auto-generated AI agent instructions (from cursor-rules)
AGENTS.md
.windsurfrules
.agents/
.copilot/
.slopmop/

# Claude Code session state (hooks, settings, transcripts)
.claude/
.cursor

# Allow agent install template files to be tracked
!slopmop/agent_install/templates/**
STATUS.md
