cursor-rules/

# Slopbucket config (user-specific, not template)
.sb_config.json
.sb_config.json.backup.*

# Generated status reports (from sm status --verbose)
sm_status_*.json

# Generated by the type-checking gate — a temp file that the gate
# writes, runs pyright against, then deletes in a finally block. If
# the gate is killed mid-run (SIGKILL, not Ctrl+C) the file leaks
# with an absolute venvPath pointing at whatever machine it ran on.
# Happened at least once (Feb 2026) — the leaked file got committed
# alongside unrelated fixes and sat in the tree for a month before
# anyone noticed the hardcoded /Users/… path. Pyright reads
# [tool.pyright] from pyproject.toml when this file is absent and
# auto-detects ./.venv — that's the intended config surface.
pyrightconfig.json
pyrightconfig.json.sm_backup

# Generated Copilot instructions (from cursor-rules)
.github/instructions/*.instructions.md

# Auto-generated AI agent instructions (from cursor-rules)
AGENTS.md
.windsurfrules
.slopmop/

# Claude Code session state (hooks, settings, transcripts)
.claude/
