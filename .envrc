# Repo-local shell overrides for slop-mop development.
# Source this file (directly or via cursor-rules/scripts/activate_env.sh)
# to ensure `sm` resolves to the checked-out repo instead of a pipx install.

REPO_ROOT="$(pwd)"

case ":${PATH}:" in
    *":${REPO_ROOT}/scripts:"*)
        ;;
    *)
        export PATH="${REPO_ROOT}/scripts:${PATH}"
        ;;
esac

# Force shells to forget a previously hashed pipx `sm` path.
hash -r 2>/dev/null || true

# Path Management for Cursor AI
export AGENT_HOME="${REPO_ROOT}"

# Ensure VIRTUAL_ENV always points to this project's venv, overriding any
# stale activation from other projects (e.g. slopbucket).
export VIRTUAL_ENV="${REPO_ROOT}/venv"
